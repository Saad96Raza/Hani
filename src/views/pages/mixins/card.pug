mixin modelCard(name, img)
    div(class="flex flex-col gap-2 md:gap-6")
        div(class="img-overlay relative")
            div(class="relative body-measurment flex flex-col h-full")
                div(class="space-y-12 location")
                    i(class="fa-brands fa-instagram fa-2xl")
                    div(class="flex gap-4 items-center")
                        span(class="text-highlight") location
                        i(class="fa-solid fa-circle text-[0.5rem]") 
                        span(class="text-highlight") brazilian   
                div(class="mt-auto space-y-5 figure")
                    div(class="grid grid-cols-2")
                        span(class="text-highlight") height
                        span(class="text-highlight text-right") 5'9
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") burst
                        span(class="text-highlight text-right") 31
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") waist
                        span(class="text-highlight text-right") 23
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") hips
                        span(class="text-highlight text-right") 34 
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") shoes
                        span(class="text-highlight text-right") 81/2 US
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") hair
                        span(class="text-highlight text-right") light brown
                    div(class="grid grid-cols-2 ")
                        span(class="text-highlight") eyes
                        span(class="text-highlight text-right") brown
            img(src=img, alt=name)
        h3(class="text-md") #{name}
