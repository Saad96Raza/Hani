include ../../mixins/buttons.pug

section(class="section contact-section-1")
    div(class="grid grid-cols-1 md:grid-cols-2 gap-12 container")
        div(class="bg") 
            img(src="./media/banners/contact.png", alt="")
        div(class="flex flex-col gap-[4rem] justify-center md:p-10")
            div(class="flex flex-col gap-12") 
                h1(class="text-xl") Contact
                p(class="text-body") For bookings and general enquiries : #[strong(class="underline text-highlight") info@hanimodels.com]
            form(action="" class="py-[calc(7.527rem/2)] contact-form")
                div(class="form grid grid-cols-2 gap-[calc(7.527rem/3)]")
                    div(class="form-group  flex flex-col gap-2") 
                        input(
                            type="text"
                            name="first-name"
                            placeholder="first name"
                            required
                            minlength="3"
                            data-pristine-pattern="/^[A-Z a-z\s\-]+$/"
                            data-pristine-required-message="Please enter your full name"
                            data-pristine-minlength-message="Minimum 3 letters required"
                            data-pristine-pattern-message="Only letters allowed"
                            class="input w-full w-full text-highlight"

                        )
                    div(class="form-group flex flex-col gap-2")       
                        input(
                            type="text" 
                            placeholder="email" 
                            data-pristine-pattern="/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/"
                            data-pristine-required-message="please enter your email" 
                            data-pristine-pattern-message="please enter valid email format"
                            class="input w-full text-highlight"
                            required
                            )
                    div(class="form-group flex flex-col col-span-2 gap-2")           
                        textarea(
                            type="text"
                            placeholder="your message" 
                            class="w-full  text-highlight"
                            minlength="40"
                            required
                            data-pristine-required-message="please write some message"
                            data-pristine-minlength-message="few lines required"

                        )
                div(class="py-[4rem]")
                    +Buttons({ text: 'message us', types: 'submit',className:'flex' })

